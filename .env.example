# MongoDB
MONGO_URI=mongodb://localhost:27017/carparts
# Or with auth: mongodb://admin:password@localhost:27017/carparts?authSource=admin

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Zarinpal Merchant ID (empty if not using gateway)
ZARINPAL_MERCHANT_ID=

# Frontend API URL (used in next.config rewrites)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_UPLOADS_URL=http://localhost:5000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PORT
PORT=5000